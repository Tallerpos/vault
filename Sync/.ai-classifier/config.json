{
  "version": "3.0",
  "api": {
    "base_url": "https://api.deepseek.com",
    "model": "deepseek-chat",
    "max_retries": 3,
    "retry_delay": 2,
    "timeout": 30
  },
  "classification": {
    "prefix": "ai_",
    "max_tags": 5,
    "debounce_seconds": 60,
    "reclassify_threshold": 0.4,
    "valid_categories": [
      "personal", "trabajo", "finanzas", "tecnologia", "aprendizaje",
      "ideas", "salud", "ocio", "familia", "proyectos", "compras",
      "viajes", "lectura", "desarrollo", "miscelanea"
    ],
    "required_fields": ["tags", "category", "summary", "importance", "key_topics"]
  },
  "learning": {
    "min_observations": 1,
    "max_few_shot_examples": 3,
    "max_tags_in_prompt": 25,
    "correction_learning": true,
    "max_recent_corrections": 3
  },
  "linking": {
    "min_score": 0.30,
    "max_links": 5,
    "weights": {
      "tag_jaccard": 0.40,
      "co_occurrence": 0.30,
      "topic_overlap": 0.20,
      "category_bonus": 0.10
    }
  },
  "tag_registry": {
    "path": "/opt/vault/Sync/.tag-registry.json",
    "aliases": {
      "finanza": "economia",
      "finanzas": "economia",
      "economía": "economia",
      "finance": "economia",
      "money": "economia",
      "dinero": "economia",
      "programacion": "programacion",
      "programación": "programacion",
      "programming": "programacion",
      "coding": "programacion",
      "dev": "programacion",
      "código": "programacion",
      "codigo": "programacion",
      "ciencia": "ciencia",
      "ciencias": "ciencia",
      "science": "ciencia",
      "tecnologia": "tecnologia",
      "tecnología": "tecnologia",
      "technology": "tecnologia",
      "tech": "tecnologia",
      "ia": "inteligencia-artificial",
      "ai": "inteligencia-artificial",
      "machine-learning": "inteligencia-artificial",
      "ml": "inteligencia-artificial",
      "deep-learning": "inteligencia-artificial",
      "llm": "inteligencia-artificial",
      "automatización": "automatizacion",
      "automatizacion": "automatizacion",
      "automation": "automatizacion",
      "clasificación": "clasificacion",
      "clasificacion": "clasificacion",
      "inversión": "inversion",
      "inversion": "inversion",
      "investing": "inversion",
      "criptomoneda": "cripto",
      "criptomonedas": "cripto",
      "cryptocurrency": "cripto",
      "crypto": "cripto",
      "alimentación": "alimentacion",
      "alimentacion": "alimentacion",
      "nutrición": "alimentacion",
      "nutricion": "alimentacion",
      "food": "comida",
      "ejercicio": "ejercicio",
      "exercise": "ejercicio",
      "fitness": "ejercicio",
      "gym": "ejercicio",
      "gimnasio": "ejercicio"
    }
  },
  "watcher": {
    "exclude_patterns": [".git", ".optimizer", ".silverbullet", ".ai-classifier", ".tag-registry"],
    "file_pattern": "*.md"
  }
}
